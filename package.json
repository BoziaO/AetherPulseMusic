{
  "name": "aetherpulse-music",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^165.0.0",
    "lucide-vue-next": "^0.468.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.10",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "scripts": {
    "client": "vite --host 0.0.0.0 --port 5000",
    "dev": "concurrently --kill-others \"npm run server:dev\" \"npm run client\"",
    "server": "node server/index.js",
    "server:dev": "node --watch-path server server/index.js",
    "start": "npm run client",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5000"
  },
  "proxy": "http://localhost:3001",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
