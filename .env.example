# ────────────────────────────────────────────────────────────
# AetherPulse Music — environment template
# Copy to `.env` and fill in only the values you actually use.
# Never commit a real `.env` to version control.
# ────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
# Port the Express API listens on during development.
# In production NODE_ENV the server uses PORT (default 5000).
BACKEND_PORT=3001

# Origin of the Vite dev server. Used for CORS allowlist and OAuth
# redirect resolution. Leave as-is unless you change Vite's port.
FRONTEND_URL=http://localhost:5000

# Secret used to sign express-session cookies.
# REQUIRED in production. Use a long random string (>=32 chars).
SESSION_SECRET=aetherpulse-dev-secret

# Set to "production" when running `npm run server` in production.
# Leave empty / unset for local development.
# NODE_ENV=production

# ── Frontend ────────────────────────────────────────────────
# Base URL the frontend prepends to every `/api/...` request.
# Leave empty during dev (Vite proxy forwards /api → :3001).
# Set to your public API origin (e.g. https://api.example.com)
# only when frontend and backend are deployed to different hosts.
VITE_API_BASE_URL=

# ── Google OAuth (optional) ─────────────────────────────────
# Required only if you want users to sign in with Google so the app
# can read their YouTube Music library (playlists, liked songs, etc.).
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Storage (optional) ──────────────────────────────────────
# Where the server persists local playlists and user state JSON.
# Defaults to a folder under the OS temp dir. Override to put data
# next to the project, e.g. ./server/.data
# AETHERPULSE_DATA_DIR=
