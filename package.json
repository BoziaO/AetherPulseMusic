{
  "name": "aetherpulse-music",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "cropperjs": "^1.6.2",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^3.0.4",
    "postcss": "^8.5.14",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.19",
    "three": "^0.184.0",
    "vuedraggable": "^4.1.0",
    "vite": "^8.0.13",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5000 && electron .\"",
    "client": "vite --host 0.0.0.0 --port 5000",
    "server": "python backend/main.py",
    "build": "prisma generate && vite build",
    "build:electron": "npm run build && electron-builder",
    "build:electron:all": "npm run build && electron-builder -mwl",
    "start": "npm run server",
    "preview": "vite preview --host 0.0.0.0 --port 5000",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "build:mobile": "npm run build && npm run cap:copy && npm run cap:sync",
    "cap:init": "npx cap init com.aetherpulse.music \"AetherPulse Music\" --web-dir=dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build:android": "npm run build:mobile && npx cap open android",
    "cap:build:ios": "npm run build:mobile && npx cap open ios",
    "cap:build": "npm run build:mobile"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@electron/rebuild": "^3.7.0",
    "concurrently": "^9.2.2",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.3",
    "electron-squirrel-startup": "^1.1.1",
    "get-port": "^7.0.0",
    "nodemon": "^3.1.4",
    "prisma": "^7.8.0",
    "terser": "^5.47.1",
    "wait-on": "^8.0.1"
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not op_mini all"
  ],
  "main": "electron/main.js",
  "build": {
    "appId": "com.aetherpulse.music",
    "productName": "AetherPulse Music",
    "directories": {
      "buildResources": "assets/icons"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons/icon.png",
      "category": "Audio"
    }
  }
}
