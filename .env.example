# ────────────────────────────────────────────────────────────
# AetherPulse Music — environment template
# Copy to `.env` and fill in only the values you actually use.
# Never commit a real `.env` to version control.
# ────────────────────────────────────────────────────────────

# ── Server (FastAPI) ────────────────────────────────────────
# Port the FastAPI backend listens on.
BACKEND_PORT=3001

# Allowed origins for CORS.
# FRONTEND_URL is used by default in development (http://localhost:5000).
# CORS_ORIGINS can be a comma-separated list of additional origins.
FRONTEND_URL=http://localhost:5000
CORS_ORIGINS=

# ── Frontend (Vite) ─────────────────────────────────────────
# Base URL the frontend prepends to every `/api/...` request.
# Leave empty during dev (Vite proxy forwards /api → :3001).
# Set to your public API origin only when frontend and backend 
# are deployed to different hosts.
VITE_API_BASE_URL=
