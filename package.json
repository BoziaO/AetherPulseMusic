{
  "name": "aetherpulse-music",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "cropperjs": "^1.6.2",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^3.0.4",
    "postcss": "^8.5.14",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.19",
    "three": "^0.184.0",
    "vuedraggable": "^4.1.0",
    "vite": "^8.0.13",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "vite",
    "client": "vite --host 0.0.0.0 --port 5000",
    "server": "node server/index.js",
    "server:python": "python backend/main.py",
    "build": "prisma generate && vite build",
    "start": "npm run server",
    "preview": "vite preview --host 0.0.0.0 --port 5000",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "build:mobile": "npm run build && npm run cap:copy",
    "cap:init": "npx cap init com.aetherpulse.music \"AetherPulse Music\" --web-dir=dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "prisma": "^7.8.0",
    "terser": "^5.47.1"
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not op_mini all"
  ]
}
